{
  "installCommand": "npm install --legacy-peer-deps --no-audit --no-fund",
  "rewrites": [
    { "source": "/docs", "destination": "https://oti-docs.vercel.app/" },
    { "source": "/docs/", "destination": "https://oti-docs.vercel.app/" },
    { "source": "/docs/:path*", "destination": "https://oti-docs.vercel.app/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
